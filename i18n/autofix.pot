#. module: autofix
#: model:mail.template,body_html:autofix.mail_template_daily_summary
msgid ""
"<div style=\"max-width:700px;margin:0 auto;font-family:Arial,Helvetica,sans-serif;color:#333;\">\n"
"                <!-- Header -->\n"
"                <div style=\"background-color:#2c3e50;color:#ffffff;padding:20px 30px;text-align:center;\">\n"
"                    <h1 style=\"margin:0;font-size:24px;\">AutoFix Management System</h1>\n"
"                    <p style=\"margin:5px 0 0;font-size:14px;opacity:0.9;\">Daily Operations Summary</p>\n"
"                </div>\n"
"\n"
"                <!-- Date Bar -->\n"
"                <div style=\"background-color:#34495e;color:#ffffff;padding:10px 30px;font-size:13px;\">\n"
"                    <strong>Report Date: </strong><t t-esc=\"today_str\"/>\n"
"                </div>\n"
"\n"
"                <div style=\"padding:20px 30px;background-color:#f9f9f9;\">\n"
"\n"
"                <!-- Section A: Work Orders -->\n"
"                <h2 style=\"color:#2c3e50;border-bottom:2px solid #3498db;padding-bottom:8px;font-size:18px;\">Section A — Work Orders Today</h2>\n"
"                <table style=\"width:100%;border-collapse:collapse;margin-bottom:25px;font-size:14px;\">\n"
"                    <tr style=\"background-color:#3498db;color:#fff;\">\n"
"                        <th style=\"padding:10px 15px;text-align:left;border:1px solid #ddd;\">Metric</th>\n"
"                        <th style=\"padding:10px 15px;text-align:right;border:1px solid #ddd;\">Count</th>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">New Work Orders</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;\"><t t-esc=\"wo_new\"/></td>\n"
"                    </tr>\n"
"                    <tr style=\"background-color:#ecf0f1;\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Completed</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#27ae60;\"><t t-esc=\"wo_completed\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">In Progress</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#f39c12;\"><t t-esc=\"wo_in_progress\"/></td>\n"
"                    </tr>\n"
"                    <tr style=\"background-color:#ecf0f1;\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Pending</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;\"><t t-esc=\"wo_pending\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Cancelled</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#e74c3c;\"><t t-esc=\"wo_cancelled\"/></td>\n"
"                    </tr>\n"
"                </table>\n"
"\n"
"                <!-- Section B: Financial Summary -->\n"
"                <h2 style=\"color:#2c3e50;border-bottom:2px solid #27ae60;padding-bottom:8px;font-size:18px;\">Section B — Financial Summary Today</h2>\n"
"                <table style=\"width:100%;border-collapse:collapse;margin-bottom:25px;font-size:14px;\">\n"
"                    <tr style=\"background-color:#27ae60;color:#fff;\">\n"
"                        <th style=\"padding:10px 15px;text-align:left;border:1px solid #ddd;\">Metric</th>\n"
"                        <th style=\"padding:10px 15px;text-align:right;border:1px solid #ddd;\">Value</th>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Invoices Created</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;\"><t t-esc=\"inv_created_count\"/></td>\n"
"                    </tr>\n"
"                    <tr style=\"background-color:#ecf0f1;\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Total Amount Invoiced</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;\"><t t-esc=\"inv_total_amount\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Total Amount Collected</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#27ae60;\"><t t-esc=\"inv_collected_amount\"/></td>\n"
"                    </tr>\n"
"                    <tr style=\"background-color:#ecf0f1;\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Unpaid Invoices</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#f39c12;\"><t t-esc=\"inv_unpaid_count\"/></td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\">Overdue Invoices</td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:right;font-weight:bold;color:#e74c3c;\"><t t-esc=\"inv_overdue_count\"/></td>\n"
"                    </tr>\n"
"                </table>\n"
"\n"
"                <!-- Section C: Mechanic Performance -->\n"
"                <h2 style=\"color:#2c3e50;border-bottom:2px solid #f39c12;padding-bottom:8px;font-size:18px;\">Section C — Mechanic Performance Today</h2>\n"
"                <t t-if=\"mechanic_rows\">\n"
"                <table style=\"width:100%;border-collapse:collapse;margin-bottom:25px;font-size:14px;\">\n"
"                    <tr style=\"background-color:#f39c12;color:#fff;\">\n"
"                        <th style=\"padding:10px 15px;text-align:left;border:1px solid #ddd;\">Mechanic</th>\n"
"                        <th style=\"padding:10px 15px;text-align:center;border:1px solid #ddd;\">Orders Handled</th>\n"
"                        <th style=\"padding:10px 15px;text-align:center;border:1px solid #ddd;\">Completed</th>\n"
"                    </tr>\n"
"                    <t t-foreach=\"mechanic_rows\" t-as=\"row\">\n"
"                    <tr t-att-style=\"'background-color:#ecf0f1;' if row_index % 2 == 0 else ''\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\"><t t-esc=\"row['name']\"/></td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:center;\"><t t-esc=\"row['total']\"/></td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:center;font-weight:bold;color:#27ae60;\"><t t-esc=\"row['completed']\"/></td>\n"
"                    </tr>\n"
"                    </t>\n"
"                </table>\n"
"                </t>\n"
"                <t t-else=\"\">\n"
"                <p style=\"color:#7f8c8d;font-style:italic;font-size:14px;\">No mechanic activity recorded today</p>\n"
"                </t>\n"
"\n"
"                <!-- Section D: Stock Alerts -->\n"
"                <h2 style=\"color:#2c3e50;border-bottom:2px solid #e74c3c;padding-bottom:8px;font-size:18px;\">Section D — Stock Alerts</h2>\n"
"                <t t-if=\"stock_alerts\">\n"
"                <table style=\"width:100%;border-collapse:collapse;margin-bottom:25px;font-size:14px;\">\n"
"                    <tr style=\"background-color:#e74c3c;color:#fff;\">\n"
"                        <th style=\"padding:10px 15px;text-align:left;border:1px solid #ddd;\">Product</th>\n"
"                        <th style=\"padding:10px 15px;text-align:center;border:1px solid #ddd;\">Current Stock</th>\n"
"                        <th style=\"padding:10px 15px;text-align:center;border:1px solid #ddd;\">Reorder Point</th>\n"
"                    </tr>\n"
"                    <t t-foreach=\"stock_alerts\" t-as=\"alert\">\n"
"                    <tr t-att-style=\"'background-color:#ecf0f1;' if alert_index % 2 == 0 else ''\">\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;\"><t t-esc=\"alert['product_name']\"/></td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:center;color:#e74c3c;font-weight:bold;\"><t t-esc=\"alert['qty_on_hand']\"/></td>\n"
"                        <td style=\"padding:8px 15px;border:1px solid #ddd;text-align:center;\"><t t-esc=\"alert['reorder_point']\"/></td>\n"
"                    </tr>\n"
"                    </t>\n"
"                </table>\n"
"                </t>\n"
"                <t t-else=\"\">\n"
"                <p style=\"color:#27ae60;font-style:italic;font-size:14px;\">All stock levels are within acceptable range</p>\n"
"                </t>\n"
"\n"
"                </div>\n"
"\n"
"                <!-- Footer -->\n"
"                <div style=\"background-color:#2c3e50;color:#bdc3c7;padding:15px 30px;text-align:center;font-size:12px;\">\n"
"                    This is an automated message generated by AutoFix Management System. Do not reply.\n"
"                </div>\n"
"            </div>"
msgstr ""

