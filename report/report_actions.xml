<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_maintenance_invoice" model="ir.actions.report">
        <field name="name">Maintenance Invoice</field>
        <field name="model">autofix.service.reception</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">autofix.maintenance_invoice_report</field>
        <field name="report_file">autofix.maintenance_invoice_report</field>
        <field name="print_report_name">'Maintenance Invoice - %s' % object.name</field>
    </record>

    <record id="action_report_inventory_audit" model="ir.actions.report">
        <field name="name">Inventory Audit</field>
        <field name="model">autofix.inventory.audit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">autofix.inventory_audit_report</field>
        <field name="report_file">autofix.inventory_audit_report</field>
        <field name="print_report_name">'Inventory Audit - %s' % object.name</field>
    </record>
</odoo>
