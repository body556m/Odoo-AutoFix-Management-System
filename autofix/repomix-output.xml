<file path="report/inventory_audit_report.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="inventory_audit_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 10pt;">
                    <div style="text-align: center; margin-bottom: 20px;">
                        <h1 style="font-size: 18pt; color: #2c3e50; margin-bottom: 5px;">AutoFix Management System</h1>
                        <h2 style="font-size: 14pt; color: #34495e;">Inventory Audit Report</h2>
                    </div>
                    
                    <div style="margin-bottom: 20px;">
                        <strong>Audit Reference:</strong> <span t-field="o.name"/><br/>
                        <strong>Period:</strong> <span t-if="o.period_type == 'monthly'">Monthly</span><span t-else="">Annual</span><br/>
                        <strong>Date Range:</strong> <span t-field="o.date_from" t-options="{&quot;format&quot;: &quot;dd/MM/yyyy&quot;}"/> to <span t-field="o.date_to" t-options="{&quot;format&quot;: &quot;dd/MM/yyyy&quot;}"/><br/>
                        <strong>Generated By:</strong> <span t-if="o.confirmed_by" t-field="o.confirmed_by.name"/><span t-else="">-</span><br/>
                        <strong>Generated Date:</strong> <span t-if="o.confirmed_date" t-field="o.confirmed_date" t-options="{&quot;format&quot;: &quot;dd/MM/yyyy HH:mm&quot;}"/><span t-else="">-</span>
                    </div>

                    <h3 style="font-size: 12pt; color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 5px;">Section 1 — Stock Inventory</h3>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 9pt;">
                        <thead>
                            <tr style="background-color: #3498db; color: white;">
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: left;">Product</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Qty on Hand</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Reorder Point</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Unit Cost</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Stock Value</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Consumed Qty</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Consumed Value</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: center;">Low Stock</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.audit_line_ids" t-as="line">
                                <tr t-attf-class="{{'low-stock-row' if line.is_low_stock else ''}}" style="background-color: {{'#fdecea' if line.is_low_stock else 'white'}};">
                                    <td style="padding: 6px; border: 1px solid #ddd;"><span t-field="line.product_name"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.qty_on_hand"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.reorder_point"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.unit_cost" t-options="{&quot;digits&quot;: 2}"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.stock_value" t-options="{&quot;digits&quot;: 2}"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.consumed_qty"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="line.consumed_value" t-options="{&quot;digits&quot;: 2}"/></td>
                                    <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><t t-if="line.is_low_stock">Yes</t><t t-else="">No</t></td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr style="background-color: #ecf0f1; font-weight: bold;">
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: right;" colspan="4">Totals:</td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: right;"><span t-field="o.total_stock_value" t-options="{&quot;digits&quot;: 2}"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: right;"><span t-field="o.total_consumed_qty"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: right;"><span t-field="o.total_consumed_value" t-options="{&quot;digits&quot;: 2}"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="o.low_stock_count"/></td>
                            </tr>
                        </tfoot>
                    </table>

                    <h3 style="font-size: 12pt; color: #2c3e50; border-bottom: 2px solid #27ae60; padding-bottom: 5px;">Section 2 — Financial Summary</h3>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <tr>
                            <td style="width: 50%; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse; font-size: 10pt;">
                                    <tr style="background-color: #27ae60; color: white;">
                                        <th style="padding: 8px; border: 1px solid #ddd; text-align: left;" colspan="2">Revenue</th>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #ddd;">Invoices Created</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.inv_created_count"/></td>
                                    </tr>
                                    <tr style="background-color: #ecf0f1;">
                                        <td style="padding: 6px; border: 1px solid #ddd;">Total Invoiced</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.inv_total_amount" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #ddd;">Collected Amount</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.inv_collected_amount" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr style="background-color: #ecf0f1;">
                                        <td style="padding: 6px; border: 1px solid #ddd;">Unpaid Amount</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.inv_unpaid_amount" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #ddd;">Overdue Count</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.inv_overdue_count"/></td>
                                    </tr>
                                </table>
                            </td>
                            <td style="width: 50%; vertical-align: top;">
                                <table style="width: 100%; border-collapse: collapse; font-size: 10pt;">
                                    <tr style="background-color: #e74c3c; color: white;">
                                        <th style="padding: 8px; border: 1px solid #ddd; text-align: left;" colspan="2">Expenses</th>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #ddd;">Petty Cash Total</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.petty_cash_total" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr style="background-color: #ecf0f1;">
                                        <td style="padding: 6px; border: 1px solid #ddd;">Labor Cost Total</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.labor_cost_total" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 6px; border: 1px solid #ddd;">Work Order Expenses</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.wo_expenses_total" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr style="background-color: #ecf0f1;">
                                        <td style="padding: 6px; border: 1px solid #ddd;">Parts Cost Total</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.parts_cost_total" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                    <tr style="font-weight: bold;">
                                        <td style="padding: 6px; border: 1px solid #ddd;">Total Expenses</td>
                                        <td style="padding: 6px; border: 1px solid #ddd; text-align: right;"><span t-field="o.total_expenses" t-options="{&quot;digits&quot;: 2}"/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 11pt;">
                        <tr style="font-weight: bold; font-size: 12pt;">
                            <td style="padding: 10px; border: 2px solid #2c3e50; text-align: center;">Gross Revenue: <span t-field="o.gross_revenue" t-options="{&quot;digits&quot;: 2}"/></td>
                            <td style="padding: 10px; border: 2px solid #2c3e50; text-align: center;">Total Expenses: <span t-field="o.total_expenses" t-options="{&quot;digits&quot;: 2}"/></td>
                            <td style="padding: 10px; border: 2px solid #2c3e50; text-align: center;" t-attf-style="color: {{'#27ae60' if o.net_result >= 0 else '#e74c3c'}};">Net Result: <span t-field="o.net_result" t-options="{&quot;digits&quot;: 2}"/></td>
                        </tr>
                    </table>

                    <h3 style="font-size: 12pt; color: #2c3e50; border-bottom: 2px solid #f39c12; padding-bottom: 5px;">Section 3 — Work Orders Summary</h3>
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 10pt;">
                        <thead>
                            <tr style="background-color: #f39c12; color: white;">
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: center;">Status</th>
                                <th style="padding: 8px; border: 1px solid #ddd; text-align: center;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 6px; border: 1px solid #ddd;">Total Work Orders</td>
                                <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><span t-field="o.wo_total"/></td>
                            </tr>
                            <tr style="background-color: #ecf0f1;">
                                <td style="padding: 6px; border: 1px solid #ddd;">Completed</td>
                                <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><span t-field="o.wo_completed"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 6px; border: 1px solid #ddd;">Cancelled</td>
                                <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><span t-field="o.wo_cancelled"/></td>
                            </tr>
                            <tr style="background-color: #ecf0f1;">
                                <td style="padding: 6px; border: 1px solid #ddd;">In Progress</td>
                                <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><span t-field="o.wo_in_progress"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 6px; border: 1px solid #ddd;">Pending</td>
                                <td style="padding: 6px; border: 1px solid #ddd; text-align: center;"><span t-field="o.wo_pending"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <t t-if="o.notes">
                        <h3 style="font-size: 12pt; color: #2c3e50; border-bottom: 2px solid #95a5a6; padding-bottom: 5px;">Notes</h3>
                        <p style="font-size: 10pt;"><span t-field="o.notes"/></p>
                    </t>

                    <div style="text-align: center; margin-top: 30px; font-size: 9pt; color: #7f8c8d; border-top: 1px solid #bdc3c7; padding-top: 10px;">
                        <p>Generated on <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/></p>
                        <p>AutoFix Management System — Confidential</p>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
</file>

