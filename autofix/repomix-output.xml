<file path="views/petty_cash_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_autofix_petty_cash_form" model="ir.ui.view">
        <field name="name">autofix.petty.cash.form</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <form string="Petty Cash">
                <header>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_reset" string="Reset" type="object" attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="category"/>
                            <field name="payment_method"/>
                            <field name="responsible_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group string="Approval Info" attrs="{'invisible': [('state', '=', 'draft')]}">
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_autofix_petty_cash_tree" model="ir.ui.view">
        <field name="name">autofix.petty.cash.tree</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <tree string="Petty Cash">
                <field name="name"/>
                <field name="date"/>
                <field name="category"/>
                <field name="description"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
                <field name="responsible_id"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_autofix_petty_cash_search" model="ir.ui.view">
        <field name="name">autofix.petty.cash.search</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <search string="Search Petty Cash">
                <field name="description"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Supplies" name="filter_supplies" domain="[('category', '=', 'supplies')]"/>
                <filter string="Maintenance" name="filter_maintenance" domain="[('category', '=', 'maintenance')]"/>
                <filter string="Utilities" name="filter_utilities" domain="[('category', '=', 'utilities')]"/>
                <filter string="Other" name="filter_other" domain="[('category', '=', 'other')]"/>
                <separator/>
                <filter string="Cash" name="filter_cash" domain="[('payment_method', '=', 'cash')]"/>
                <filter string="Network" name="filter_network" domain="[('payment_method', '=', 'network')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Payment Method" name="group_payment" context="{'group_by': 'payment_method'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
</file>

<file path="views/service_reception_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_autofix_service_reception_form" model="ir.ui.view">
        <field name="name">autofix.service.reception.form</field>
        <field name="model">autofix.service.reception</field>
        <field name="arch" type="xml">
            <form string="Service Reception">
                <header>
                    <button name="action_create_invoice" string="Create Invoice" type="object"
                            class="oe_highlight"
                            groups="autofix.group_autofix_manager"
                            invisible="state != 'done' or invoice_count &gt; 0"/>
                    <button name="action_print_maintenance_report" string="Print Invoice" type="object"
                            groups="autofix.group_autofix_manager"
                            invisible="invoice_count == 0"/>
                    <button name="action_start" string="Start" type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-pencil-square-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="left_details">
                            <field name="partner_id"/>
                            <field name="car_id" domain="[('partner_id', '=', partner_id)]"/>
                            <field name="date_received"/>
                            <field name="date_expected"/>
                        </group>
                        <group name="right_details">
                            <field name="mileage_on_arrival"/>
                            <field name="total_cost" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="complaint" placeholder="Customer complaint..."/>
                    </group>
                    <notebook>
                        <page string="Work Orders" name="work_orders">
                            <field name="work_order_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'pending'"
                                           decoration-warning="state == 'in_progress'"
                                           decoration-success="state == 'done'"
                                           decoration-danger="state == 'cancelled'"/>
                                    <field name="estimated_hours" widget="float_time"/>
                                    <field name="actual_hours" widget="float_time"/>
                                    <field name="labor_cost"/>
                                    <field name="total_cost" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_autofix_service_reception_tree" model="ir.ui.view">
        <field name="name">autofix.service.reception.tree</field>
        <field name="model">autofix.service.reception</field>
        <field name="arch" type="xml">
            <tree string="Service Receptions" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <header>
                    <button name="action_print_maintenance_report" string="Print Invoices" type="object"/>
                </header>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <field name="date_received"/>
                <field name="total_cost"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_autofix_service_reception_search" model="ir.ui.view">
        <field name="name">autofix.service.reception.search</field>
        <field name="model">autofix.service.reception</field>
        <field name="arch" type="xml">
            <search string="Search Receptions">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Date Received" name="group_date" context="{'group_by': 'date_received'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
</file>

