<file path="views/vehicle_inspection_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inspection Template Form View -->
    <record id="view_inspection_template_form" model="ir.ui.view">
        <field name="name">autofix.inspection.template.form</field>
        <field name="model">autofix.inspection.template</field>
        <field name="arch" type="xml">
            <form string="Inspection Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group string="Checklist Items">
                        <field name="line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="category"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Inspection Template Tree View -->
    <record id="view_inspection_template_tree" model="ir.ui.view">
        <field name="name">autofix.inspection.template.tree</field>
        <field name="model">autofix.inspection.template</field>
        <field name="arch" type="xml">
            <tree string="Inspection Templates">
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vehicle Inspection Form View -->
    <record id="view_vehicle_inspection_form" model="ir.ui.view">
        <field name="name">autofix.vehicle.inspection.form</field>
        <field name="model">autofix.vehicle.inspection</field>
        <field name="arch" type="xml">
            <form string="Vehicle Inspection">
                <header>
                    <button name="action_generate_from_template" string="Generate from Template" type="object" class="btn-primary"/>
                    <button name="action_done" string="Complete" type="object" class="btn-success" attrs="{'invisible': [('state', '=', 'done')]}"/>
                    <button name="action_reset" string="Reset to Draft" type="object" attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="reception_id"/>
                            <field name="template_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="inspector_id"/>
                            <field name="overall_condition"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Checklist" name="checklist">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="condition" widget="badge" decoration-success="condition == 'good'" decoration-warning="condition == 'fair'" decoration-danger="condition == 'poor'" decoration-danger="condition == 'critical'"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vehicle Inspection Tree View -->
    <record id="view_vehicle_inspection_tree" model="ir.ui.view">
        <field name="name">autofix.vehicle.inspection.tree</field>
        <field name="model">autofix.vehicle.inspection</field>
        <field name="arch" type="xml">
            <tree string="Vehicle Inspections">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="inspector_id"/>
                <field name="date"/>
                <field name="overall_condition" widget="badge" decoration-success="overall_condition == 'good'" decoration-warning="overall_condition == 'fair'" decoration-danger="overall_condition == 'poor'" decoration-danger="overall_condition == 'critical'"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Vehicle Inspection Search View -->
    <record id="view_vehicle_inspection_search" model="ir.ui.view">
        <field name="name">autofix.vehicle.inspection.search</field>
        <field name="model">autofix.vehicle.inspection</field>
        <field name="arch" type="xml">
            <search string="Search Inspections">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="inspector_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Completed" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today())]"/>
                <group expand="0" string="Group By">
                    <filter string="Inspector" name="group_inspector" context="{'group_by': 'inspector_id'}"/>
                    <filter string="Condition" name="group_condition" context="{'group_by': 'overall_condition'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
</file>

<file path="views/warranty_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Warranty Form View -->
    <record id="view_warranty_form" model="ir.ui.view">
        <field name="name">autofix.warranty.form</field>
        <field name="model">autofix.warranty</field>
        <field name="arch" type="xml">
            <form string="Warranty">
                <header>
                    <button name="action_claim" string="File Claim" type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,expired,claimed,void"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="reception_id"/>
                            <field name="work_order_id"/>
                            <field name="car_id"/>
                        </group>
                        <group>
                            <field name="warranty_type"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_months"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Claims" name="claims">
                            <field name="claim_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="claim_date"/>
                                    <field name="state" widget="badge"/>
                                    <field name="resolution"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Warranty Tree View -->
    <record id="view_warranty_tree" model="ir.ui.view">
        <field name="name">autofix.warranty.tree</field>
        <field name="model">autofix.warranty</field>
        <field name="arch" type="xml">
            <tree string="Warranties">
                <field name="name"/>
                <field name="car_id"/>
                <field name="warranty_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-warning="state == 'expired'" decoration-info="state == 'claimed'" decoration-danger="state == 'void'"/>
            </tree>
        </field>
    </record>

    <!-- Warranty Search View -->
    <record id="view_warranty_search" model="ir.ui.view">
        <field name="name">autofix.warranty.search</field>
        <field name="model">autofix.warranty</field>
        <field name="arch" type="xml">
            <search string="Search Warranties">
                <field name="name"/>
                <field name="car_id"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Expiring Soon" name="expiring_soon" domain="[('state', '=', 'active'), ('end_date', '&lt;=', context_today() + timedelta(days=30))]"/>
            </search>
        </field>
    </record>

    <!-- Warranty Claim Form View -->
    <record id="view_warranty_claim_form" model="ir.ui.view">
        <field name="name">autofix.warranty.claim.form</field>
        <field name="model">autofix.warranty.claim</field>
        <field name="arch" type="xml">
            <form string="Warranty Claim">
                <header>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" attrs="{'invisible': [('state', '!=', 'pending')]}"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" attrs="{'invisible': [('state', '!=', 'pending')]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="warranty_id"/>
                            <field name="claim_date"/>
                            <field name="claimed_by"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="resolution"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Warranty Claim Tree View -->
    <record id="view_warranty_claim_tree" model="ir.ui.view">
        <field name="name">autofix.warranty.claim.tree</field>
        <field name="model">autofix.warranty.claim</field>
        <field name="arch" type="xml">
            <tree string="Warranty Claims">
                <field name="name"/>
                <field name="warranty_id"/>
                <field name="claim_date"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
</odoo>
</file>

<file path="views/work_order_views.xml">
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_autofix_work_order_form" model="ir.ui.view">
        <field name="name">autofix.work.order.form</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <form string="Work Order">
                <header>
                    <button name="action_start" string="Start" type="object"
                            class="oe_highlight"
                            invisible="state != 'pending'"/>
                    <button name="action_done" string="Done" type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state != 'pending'"/>
                    <button name="action_reset_to_pending" string="Reset to Pending" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="left_details">
                            <field name="reception_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="car_id" readonly="1"/>
                            <field name="service_type_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group name="right_details">
                            <field name="employee_id"/>
                            <field name="estimated_hours" widget="float_time"/>
                            <field name="actual_hours" widget="float_time"/>
                            <field name="labor_cost"/>
                            <field name="deadline"/>
                            <field name="is_warranty_repair"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Work description..."/>
                    </group>
                    <group string="Time Tracking">
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group>
                            <field name="warranty_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_expenses" readonly="1"/>
                                <field name="total_parts_cost" readonly="1"/>
                                <field name="total_cost" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Parts Used" name="parts">
                            <field name="part_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="amount" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_parts_cost" readonly="1"/>
                            </group>
                        </page>
                        <page string="Quality Check" name="quality">
                            <group>
                                <field name="quality_check"/>
                                <field name="quality_notes"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_autofix_work_order_tree" model="ir.ui.view">
        <field name="name">autofix.work.order.tree</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <tree string="Work Orders" decoration-info="state == 'pending'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="employee_id"/>
                <field name="priority" widget="priority"/>
                <field name="deadline"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="estimated_hours" widget="float_time"/>
                <field name="labor_cost"/>
                <field name="total_cost" sum="Total"/>
                <field name="duration" widget="float_time"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_autofix_work_order_kanban" model="ir.ui.view">
        <field name="name">autofix.work.order.kanban</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <field name="employee_id"/>
                <field name="priority"/>
                <field name="deadline"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_details">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_head">
                                    <strong t-esc="record.name.value"/>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <span>Customer: </span>
                                    <t t-esc="record.partner_id.value"/>
                                </div>
                                <div>
                                    <span>Car: </span>
                                    <t t-esc="record.car_id.value"/>
                                </div>
                                <div>
                                    <span>Mechanic: </span>
                                    <t t-esc="record.employee_id.value"/>
                                </div>
                                <div t-if="record.deadline.value">
                                    <span>Deadline: </span>
                                    <t t-esc="record.deadline.value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_autofix_work_order_search" model="ir.ui.view">
        <field name="name">autofix.work.order.search</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <search string="Search Work Orders">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('priority', '=', '3')]"/>
                <filter string="High Priority" name="filter_high_priority" domain="[('priority', 'in', ['2', '3'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Mechanic" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Reception" name="group_reception" context="{'group_by': 'reception_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
</file>

