<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Appointment Form View -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">autofix.appointment.form</field>
        <field name="model">autofix.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_arrived" string="Create Reception" type="object" class="btn-success" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancelled', 'no_show')"/>
                    <button name="action_no_show" string="No Show" type="object" invisible="state not in ('draft', 'confirmed')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,arrived,cancelled,no_show"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="car_id"/>
                            <field name="service_type_id"/>
                        </group>
                        <group>
                            <field name="appointment_date"/>
                            <field name="time_slot"/>
                            <field name="reminder_sent"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <group string="Created Reception" invisible="not reception_id">
                        <field name="reception_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Appointment Tree View -->
    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">autofix.appointment.tree</field>
        <field name="model">autofix.appointment</field>
        <field name="arch" type="xml">
            <tree string="Appointments">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <field name="appointment_date"/>
                <field name="time_slot"/>
                <field name="service_type_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'" decoration-warning="state == 'arrived'" decoration-danger="state == 'cancelled'" decoration-muted="state == 'no_show'"/>
            </tree>
        </field>
    </record>

    <!-- Appointment Calendar View -->
    <record id="view_appointment_calendar" model="ir.ui.view">
        <field name="name">autofix.appointment.calendar</field>
        <field name="model">autofix.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="appointment_date" color="state" mode="month">
                <field name="partner_id"/>
                <field name="car_id"/>
                <field name="time_slot"/>
            </calendar>
        </field>
    </record>

    <!-- Appointment Search View -->
    <record id="view_appointment_search" model="ir.ui.view">
        <field name="name">autofix.appointment.search</field>
        <field name="model">autofix.appointment</field>
        <field name="arch" type="xml">
            <search string="Search Appointments">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <filter string="Today" name="today" domain="[('appointment_date', '=', context_today())]"/>
                <filter string="Upcoming" name="upcoming" domain="[('appointment_date', '>=', context_today())]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'appointment_date'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>