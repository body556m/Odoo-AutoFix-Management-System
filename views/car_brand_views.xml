<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Brand Form View -->
    <record id="view_car_brand_form" model="ir.ui.view">
        <field name="name">autofix.car.brand.form</field>
        <field name="model">autofix.car.brand</field>
        <field name="arch" type="xml">
            <form string="Car Brand">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="country"/>
                            <field name="model_count" string="Number of Models"/>
                        </group>
                        <group>
                            <field name="logo" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <group string="Models">
                        <field name="model_ids" nolabel="1" colspan="2">
                            <tree editable="bottom">
                                <field name="name"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Car Brand Tree View -->
    <record id="view_car_brand_tree" model="ir.ui.view">
        <field name="name">autofix.car.brand.tree</field>
        <field name="model">autofix.car.brand</field>
        <field name="arch" type="xml">
            <tree string="Car Brands">
                <field name="name"/>
                <field name="country"/>
                <field name="model_count"/>
            </tree>
        </field>
    </record>

    <!-- Car Brand Search View -->
    <record id="view_car_brand_search" model="ir.ui.view">
        <field name="name">autofix.car.brand.search</field>
        <field name="model">autofix.car.brand</field>
        <field name="arch" type="xml">
            <search string="Search Brands">
                <field name="name"/>
                <field name="country"/>
            </search>
        </field>
    </record>

    <!-- Car Model Form View -->
    <record id="view_car_model_form" model="ir.ui.view">
        <field name="name">autofix.car.model.form</field>
        <field name="model">autofix.car.model</field>
        <field name="arch" type="xml">
            <form string="Car Model">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="brand_id"/>
                        <field name="car_count" string="Registered Cars"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Car Model Tree View -->
    <record id="view_car_model_tree" model="ir.ui.view">
        <field name="name">autofix.car.model.tree</field>
        <field name="model">autofix.car.model</field>
        <field name="arch" type="xml">
            <tree string="Car Models">
                <field name="name"/>
                <field name="brand_id"/>
                <field name="car_count"/>
            </tree>
        </field>
    </record>

    <!-- Car Model Search View -->
    <record id="view_car_model_search" model="ir.ui.view">
        <field name="name">autofix.car.model.search</field>
        <field name="model">autofix.car.model</field>
        <field name="arch" type="xml">
            <search string="Search Models">
                <field name="name"/>
                <field name="brand_id"/>
            </search>
        </field>
    </record>
</odoo>