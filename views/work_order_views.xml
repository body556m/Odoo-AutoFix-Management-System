<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_autofix_work_order_form" model="ir.ui.view">
        <field name="name">autofix.work.order.form</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <form string="Work Order">
                <header>
                    <button name="action_start" string="Start" type="object"
                            class="oe_highlight"
                            invisible="state != 'pending'"/>
                    <button name="action_done" string="Done" type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state != 'pending'"/>
                    <button name="action_reset_to_pending" string="Reset to Pending" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="left_details">
                            <field name="reception_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="car_id" readonly="1"/>
                            <field name="service_type_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group name="right_details">
                            <field name="employee_id"/>
                            <field name="estimated_hours" widget="float_time"/>
                            <field name="actual_hours" widget="float_time"/>
                            <field name="labor_cost"/>
                            <field name="deadline"/>
                            <field name="is_warranty_repair"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Work description..."/>
                    </group>
                    <group string="Time Tracking">
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group>
                            <field name="warranty_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_expenses" readonly="1"/>
                                <field name="total_parts_cost" readonly="1"/>
                                <field name="total_cost" readonly="1" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Parts Used" name="parts">
                            <field name="part_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="amount" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_parts_cost" readonly="1"/>
                            </group>
                        </page>
                        <page string="Quality Check" name="quality">
                            <group>
                                <field name="quality_check"/>
                                <field name="quality_notes"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_autofix_work_order_tree" model="ir.ui.view">
        <field name="name">autofix.work.order.tree</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <tree string="Work Orders" decoration-info="state == 'pending'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="employee_id"/>
                <field name="priority" widget="priority"/>
                <field name="deadline"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="estimated_hours" widget="float_time"/>
                <field name="labor_cost"/>
                <field name="total_cost" sum="Total"/>
                <field name="duration" widget="float_time"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_autofix_work_order_kanban" model="ir.ui.view">
        <field name="name">autofix.work.order.kanban</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="car_id"/>
                <field name="employee_id"/>
                <field name="priority"/>
                <field name="deadline"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_details">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_head">
                                    <strong t-esc="record.name.value"/>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <span>Customer: </span>
                                    <t t-esc="record.partner_id.value"/>
                                </div>
                                <div>
                                    <span>Car: </span>
                                    <t t-esc="record.car_id.value"/>
                                </div>
                                <div>
                                    <span>Mechanic: </span>
                                    <t t-esc="record.employee_id.value"/>
                                </div>
                                <div t-if="record.deadline.value">
                                    <span>Deadline: </span>
                                    <t t-esc="record.deadline.value"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_autofix_work_order_search" model="ir.ui.view">
        <field name="name">autofix.work.order.search</field>
        <field name="model">autofix.work.order</field>
        <field name="arch" type="xml">
            <search string="Search Work Orders">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <filter string="Urgent" name="filter_urgent" domain="[('priority', '=', '3')]"/>
                <filter string="High Priority" name="filter_high_priority" domain="[('priority', 'in', ['2', '3'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Mechanic" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Reception" name="group_reception" context="{'group_by': 'reception_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
