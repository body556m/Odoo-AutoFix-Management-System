<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_autofix_petty_cash_form" model="ir.ui.view">
        <field name="name">autofix.petty.cash.form</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <form string="Petty Cash">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="category"/>
                            <field name="payment_method"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_autofix_petty_cash_tree" model="ir.ui.view">
        <field name="name">autofix.petty.cash.tree</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <tree string="Petty Cash">
                <field name="name"/>
                <field name="date"/>
                <field name="category"/>
                <field name="description"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_autofix_petty_cash_search" model="ir.ui.view">
        <field name="name">autofix.petty.cash.search</field>
        <field name="model">autofix.petty.cash</field>
        <field name="arch" type="xml">
            <search string="Search Petty Cash">
                <field name="description"/>
                <separator/>
                <filter string="Supplies" name="filter_supplies" domain="[('category', '=', 'supplies')]"/>
                <filter string="Maintenance" name="filter_maintenance" domain="[('category', '=', 'maintenance')]"/>
                <filter string="Utilities" name="filter_utilities" domain="[('category', '=', 'utilities')]"/>
                <filter string="Other" name="filter_other" domain="[('category', '=', 'other')]"/>
                <separator/>
                <filter string="Cash" name="filter_cash" domain="[('payment_method', '=', 'cash')]"/>
                <filter string="Network" name="filter_network" domain="[('payment_method', '=', 'network')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Payment Method" name="group_payment" context="{'group_by': 'payment_method'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
