<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customer Feedback Form View -->
    <record id="view_customer_feedback_form" model="ir.ui.view">
        <field name="name">autofix.customer.feedback.form</field>
        <field name="model">autofix.customer.feedback</field>
        <field name="arch" type="xml">
            <form string="Customer Feedback">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="reception_id"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="rating" widget="priority"/>
                            <field name="would_recommend"/>
                        </group>
                    </group>
                    <group string="Ratings">
                        <group>
                            <field name="service_quality"/>
                            <field name="timeliness"/>
                        </group>
                        <group>
                            <field name="cleanliness"/>
                        </group>
                    </group>
                    <group string="Comments">
                        <field name="comment" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Customer Feedback Tree View -->
    <record id="view_customer_feedback_tree" model="ir.ui.view">
        <field name="name">autofix.customer.feedback.tree</field>
        <field name="model">autofix.customer.feedback</field>
        <field name="arch" type="xml">
            <tree string="Customer Feedback">
                <field name="name"/>
                <field name="reception_id"/>
                <field name="partner_id"/>
                <field name="rating" widget="priority"/>
                <field name="service_quality"/>
                <field name="would_recommend" widget="boolean"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <!-- Customer Feedback Graph View -->
    <record id="view_customer_feedback_graph" model="ir.ui.view">
        <field name="name">autofix.customer.feedback.graph</field>
        <field name="model">autofix.customer.feedback</field>
        <field name="arch" type="xml">
            <graph string="Feedback Ratings">
                <field name="rating" type="row"/>
                <field name="rating" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Customer Feedback Search View -->
    <record id="view_customer_feedback_search" model="ir.ui.view">
        <field name="name">autofix.customer.feedback.search</field>
        <field name="model">autofix.customer.feedback</field>
        <field name="arch" type="xml">
            <search string="Search Feedback">
                <field name="reception_id"/>
                <field name="partner_id"/>
                <filter string="5 Stars" name="five_star" domain="[('rating', '=', '5')]"/>
                <filter string="Would Recommend" name="recommend" domain="[('would_recommend', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Rating" name="group_rating" context="{'group_by': 'rating'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>