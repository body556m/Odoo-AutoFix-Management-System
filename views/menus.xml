<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Top menu item -->
        <menuitem id="autofix_menu_root"
                  name="AutoFix"
                  sequence="10"/>

        <!-- Action for cars -->
        <record id="action_autofix_car" model="ir.actions.act_window">
            <field name="name">Cars</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">autofix.car</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Register a new Car!
              </p>
            </field>
        </record>

        <!-- Menu for cars -->
        <menuitem id="autofix_car_menu"
                  name="Cars"
                  parent="autofix_menu_root"
                  action="action_autofix_car"
                  sequence="10"/>
    </data>
</odoo>
